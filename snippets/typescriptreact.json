  "API / apiClient": {
    "prefix": "apiClient",
    "body": [
      "type ApiError = {",
      "  status: number;",
      "  message: string;",
      "  details?: unknown;",
      "};",
      "",
      "type ApiResult<T> =",
      "  | { ok: true; data: T }",
      "  | { ok: false; error: ApiError };",
      "",
      "type RequestOptions<B = unknown> = {",
      "  method?: 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';",
      "  headers?: Record<string, string>;",
      "  query?: Record<string, string | number | boolean | undefined | null>;",
      "  body?: B;",
      "  signal?: AbortSignal;",
      "};",
      "",
      "const buildUrl = (base: string, path: string, query?: RequestOptions['query']) => {",
      "  const origin = typeof window !== 'undefined' ? window.location.origin : 'http://localhost';",
      "  const baseAbs = base.startsWith('http') ? base : origin + base;",
      "  const url = new URL(path, baseAbs);",
      "  if (query) {",
      "    for (const [k, v] of Object.entries(query)) {",
      "      if (v === undefined || v === null) continue;",
      "      url.searchParams.set(k, String(v));",
      "    }",
      "  }",
      "  return url.toString();",
      "};",
      "",
      "export const createApiClient = (baseUrl: string, getAuthHeader?: () => string | undefined) => {",
      "  const request = async <T, B = unknown>(path: string, opts: RequestOptions<B> = {}): Promise<ApiResult<T>> => {",
      "    try {",
      "      const url = buildUrl(baseUrl, path, opts.query);",
      "      const auth = getAuthHeader?.();",
      "",
      "      const res = await fetch(url, {",
      "        method: opts.method ?? (opts.body ? 'POST' : 'GET'),",
      "        headers: {",
      "          ...(opts.body ? { 'Content-Type': 'application/json' } : {}),",
      "          ...(auth ? { Authorization: auth } : {}),",
      "          ...opts.headers,",
      "        },",
      "        body: opts.body ? JSON.stringify(opts.body) : undefined,",
      "        signal: opts.signal,",
      "      });",
      "",
      "      if (!res.ok) {",
      "        let details: unknown = undefined;",
      "        try { details = await res.json(); } catch { }",
      "        return { ok: false, error: { status: res.status, message: res.statusText, details } };",
      "      }",
      "",
      "      if (res.status === 204) return { ok: true, data: undefined as T };",
      "",
      "      const contentType = res.headers.get('content-type') ?? '';",
      "      if (!contentType.includes('application/json')) {",
      "        return { ok: true, data: (await res.text()) as unknown as T };",
      "      }",
      "",
      "      const data = (await res.json()) as T;",
      "      return { ok: true, data };",
      "    } catch (err) {",
      "      const message = err instanceof Error ? err.message : 'Request failed';",
      "      return { ok: false, error: { status: 0, message, details: err } };",
      "    }",
      "  };",
      "",
      "  return { request };",
      "};"
    ],
    "description": "API client"
  },

  "API / apiErrorNarrow": {
    "prefix": "apiErrorNarrow",
    "body": [
      "type ApiError = { status: number; message: string; details?: unknown };",
      "type ApiResult<T> = { ok: true; data: T } | { ok: false; error: ApiError };",
      "",
      "const isApiError = (r: ApiResult<unknown>): r is { ok: false; error: ApiError } => !r.ok;"
    ],
    "description": "ApiResult narrow"
  },

  "API / apiSchema": {
    "prefix": "apiSchema",
    "body": [
      "import { z } from 'zod';",
      "",
      "export const ${1:ResponseSchema} = z.object({",
      "  ${2:id}: z.string(),",
      "});",
      "",
      "export type ${3:Response} = z.infer<typeof ${1:ResponseSchema}>;",
      "",
      "export const ${4:fetchThing} = async () => {",
      "  const res = await fetch(${5:\"/api/thing\"});",
      "  if (!res.ok) throw new Error(res.statusText);",
      "  const json = await res.json();",
      "  return ${1:ResponseSchema}.parse(json);",
      "};"
    ],
    "description": "endpoint + schema"
  },

  "API / apiEndpoints": {
    "prefix": "apiEndpoints",
    "body": [
      "type EndpointDef = { method: 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE'; path: string };",
      "type Endpoints = Record<string, EndpointDef>;",
      "",
      "type ExtractPathParams<P extends string> =",
      "  P extends `${string}:${infer Param}/${infer Rest}`",
      "    ? Param | ExtractPathParams<`/${Rest}`>",
      "    : P extends `${string}:${infer Param}`",
      "      ? Param",
      "      : never;",
      "",
      "type PathParams<P extends string> = ExtractPathParams<P> extends never",
      "  ? {}",
      "  : { [K in ExtractPathParams<P>]: string | number };",
      "",
      "const compilePath = (path: string, params: Record<string, string | number>) =>",
      "  path.replace(/:([A-Za-z0-9_]+)/g, (_, k) => encodeURIComponent(String(params[k])));",
      "",
      "export const endpoints = {",
      "  ${1:getUser}: { method: 'GET', path: '/users/:id' },",
      "  ${2:updateUser}: { method: 'PATCH', path: '/users/:id' },",
      "} satisfies Endpoints;",
      "",
      "type EndpointKey = keyof typeof endpoints;",
      "",
      "type ApiShapes = {",
      "  ${1:getUser}: {",
      "    params: PathParams<(typeof endpoints)['${1:getUser}']['path']>;",
      "    query?: { ${3:include}?: string };",
      "    body?: never;",
      "    response: ${4:User};",
      "  };",
      "  ${2:updateUser}: {",
      "    params: PathParams<(typeof endpoints)['${2:updateUser}']['path']>;",
      "    query?: never;",
      "    body: ${5:UpdateUser};",
      "    response: ${4:User};",
      "  };",
      "};",
      "",
      "export const createApi = (client: { request: <T, B = unknown>(path: string, opts: any) => Promise<any> }) => ({",
      "  call: async <K extends EndpointKey>(key: K, input: ApiShapes[K]) => {",
      "    const def = endpoints[key];",
      "    const path = compilePath(def.path, (input as any).params ?? {});",
      "    return client.request<ApiShapes[K]['response'], ApiShapes[K]['body']>(path, {",
      "      method: def.method,",
      "      query: (input as any).query,",
      "      body: (input as any).body,",
      "    });",
      "  },",
      "});"
    ],
    "description": "endpoints map"
  },

  "Forms / formNoLibs": {
  "prefix": "form",
  "body": [
    "type FormValues = {",
    "  ${1:name}: ${2:string};",
    "};",
    "",
    "type FormErrors = Partial<Record<keyof FormValues, string>>;",
    "",
    "const validate = (values: FormValues): FormErrors => {",
    "  const errors: FormErrors = {};",
    "  ${3:// errors.name = values.name.trim() ? undefined : 'Required';}",
    "  return errors;",
    "};",
    "",
    "export const ${TM_FILENAME_BASE} = () => {",
    "  const [values, setValues] = useState<FormValues>({",
    "    ${1:name}: ${4:\"\" as any},",
    "  });",
    "  const [errors, setErrors] = useState<FormErrors>({});",
    "  const [isSubmitting, setIsSubmitting] = useState(false);",
    "",
    "  const setField = <K extends keyof FormValues>(key: K, value: FormValues[K]) => {",
    "    setValues((prev) => ({ ...prev, [key]: value }));",
    "    setErrors((prev) => ({ ...prev, [key]: undefined }));",
    "  };",
    "",
    "  const onSubmit = async (e: React.FormEvent<HTMLFormElement>) => {",
    "    e.preventDefault();",
    "    setIsSubmitting(true);",
    "",
    "    const nextErrors = validate(values);",
    "    setErrors(nextErrors);",
    "    if (Object.values(nextErrors).some(Boolean)) {",
    "      setIsSubmitting(false);",
    "      return;",
    "    }",
    "",
    "    try {",
    "      ${5:// submit values}",
    "    } finally {",
    "      setIsSubmitting(false);",
    "    }",
    "  };",
    "",
    "  return (",
    "    <form onSubmit={onSubmit} noValidate>",
    "      <label>",
    "        ${1:name}",
    "        <input",
    "          value={values.${1:name} as any}",
    "          onChange={(e) => setField('${1:name}', e.target.value as any)}",
    "          aria-invalid={!!errors.${1:name}}",
    "        />",
    "      </label>",
    "      {errors.${1:name} && <div role=\"alert\">{errors.${1:name}}</div>}",
    "",
    "      <button type=\"submit\" disabled={isSubmitting}>Submit</button>",
    "    </form>",
    "  );",
    "};"
  ],
  "description": "controlled form + manual validate (no libs)"
},

  "Forms / formZodNoRHF": {
  "prefix": "formZod",
  "body": [
    "import { z } from 'zod';",
    "",
    "const schema = z.object({",
    "  ${1:name}: z.string().min(1),",
    "});",
    "",
    "type FormValues = z.infer<typeof schema>;",
    "",
    "export const ${TM_FILENAME_BASE} = () => {",
    "  const [values, setValues] = useState<FormValues>({",
    "    ${1:name}: ${2:\"\"},",
    "  });",
    "  const [errors, setErrors] = useState<Partial<Record<keyof FormValues, string>>>({});",
    "  const [isSubmitting, setIsSubmitting] = useState(false);",
    "",
    "  const onChange = <K extends keyof FormValues>(key: K) =>",
    "    (e: React.ChangeEvent<HTMLInputElement>) => {",
    "      const next = { ...values, [key]: e.target.value } as FormValues;",
    "      setValues(next);",
    "      setErrors((prev) => ({ ...prev, [key]: undefined }));",
    "    };",
    "",
    "  const onSubmit = async (e: React.FormEvent<HTMLFormElement>) => {",
    "    e.preventDefault();",
    "    setIsSubmitting(true);",
    "    setErrors({});",
    "",
    "    const parsed = schema.safeParse(values);",
    "    if (!parsed.success) {",
    "      const nextErrors: Partial<Record<keyof FormValues, string>> = {};",
    "      for (const issue of parsed.error.issues) {",
    "        const k = issue.path[0] as keyof FormValues | undefined;",
    "        if (k && nextErrors[k] == null) nextErrors[k] = issue.message;",
    "      }",
    "      setErrors(nextErrors);",
    "      setIsSubmitting(false);",
    "      return;",
    "    }",
    "",
    "    try {",
    "      ${3:// submit parsed.data}",
    "    } finally {",
    "      setIsSubmitting(false);",
    "    }",
    "  };",
    "",
    "  return (",
    "    <form onSubmit={onSubmit} noValidate>",
    "      <label>",
    "        ${1:name}",
    "        <input",
    "          value={values.${1:name}}",
    "          onChange={onChange('${1:name}')}",
    "          aria-invalid={!!errors.${1:name}}",
    "        />",
    "      </label>",
    "      {errors.${1:name} && <div role=\"alert\">{errors.${1:name}}</div>}",
    "",
    "      <button type=\"submit\" disabled={isSubmitting}>Submit</button>",
    "    </form>",
    "  );",
    "};"
  ],
  "description": "Zod + controlled form (no react-hook-form)"
},

 "Forms / rhfZodAllInOne": {
  "prefix": "formRHFZod",
  "body": [
    "import { z } from 'zod';",
    "import { zodResolver } from '@hookform/resolvers/zod';",
    "import { Controller, useFieldArray, useForm } from 'react-hook-form';",
    "",
    "const schema = z.object({",
    "  ${1:name}: z.string().min(1),",
    "  ${2:items}: z.array(z.object({",
    "    ${3:label}: z.string().min(1),",
    "  })).default([]),",
    "});",
    "",
    "type FormValues = z.infer<typeof schema>;",
    "",
    "export const ${TM_FILENAME_BASE} = () => {",
    "  const {",
    "    register,",
    "    handleSubmit,",
    "    control,",
    "    formState: { errors, isSubmitting },",
    "  } = useForm<FormValues>({",
    "    resolver: zodResolver(schema),",
    "    mode: 'onSubmit',",
    "    reValidateMode: 'onChange',",
    "    defaultValues: {",
    "      ${1:name}: ${4:\"\"},",
    "      ${2:items}: [],",
    "    },",
    "  });",
    "",
    "  const { fields, append, remove } = useFieldArray({",
    "    control,",
    "    name: '${2:items}',",
    "  });",
    "",
    "  const onSubmit = handleSubmit(async (values: FormValues) => {",
    "    ${5}",
    "  });",
    "",
    "  return (",
    "    <form onSubmit={onSubmit} noValidate>",
    "      <label>",
    "        ${1:name}",
    "        <input",
    "          {...register('${1:name}')}",
    "          aria-invalid={!!errors.${1:name}}",
    "        />",
    "      </label>",
    "      {errors.${1:name} && <div role=\"alert\">{errors.${1:name}.message}</div>}",
    "",
    "      <div>",
    "        <button type=\"button\" onClick={() => append({ ${3:label}: ${6:\"\"} })}>",
    "          Add ${2:items}",
    "        </button>",
    "        {fields.map((field, index) => (",
    "          <div key={field.id}>",
    "            <input",
    "              {...register(`${2:items}.${index}.${3:label}` as const)}",
    "            />",
    "            <button type=\"button\" onClick={() => remove(index)}>Remove</button>",
    "          </div>",
    "        ))}",
    "      </div>",
    "",
    "      <Controller",
    "        control={control}",
    "        name={'${7:someControlledField}' as const}",
    "        render={({ field }) => (",
    "          <${8:Component} {...field} ${9} />",
    "        )}",
    "      />",
    "",
    "      <button type=\"submit\" disabled={isSubmitting}>Submit</button>",
    "    </form>",
    "  );",
    "};"
  ],
  "description": "RHF + Zod (schema + useForm + register + useFieldArray + Controller)"
}
}
