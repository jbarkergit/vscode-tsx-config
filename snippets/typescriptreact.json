  "API / apiClient": {
    "prefix": "apiClient",
    "body": [
      "type ApiError = {",
      "  status: number;",
      "  message: string;",
      "  details?: unknown;",
      "};",
      "",
      "type ApiResult<T> =",
      "  | { ok: true; data: T }",
      "  | { ok: false; error: ApiError };",
      "",
      "type RequestOptions<B = unknown> = {",
      "  method?: 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';",
      "  headers?: Record<string, string>;",
      "  query?: Record<string, string | number | boolean | undefined | null>;",
      "  body?: B;",
      "  signal?: AbortSignal;",
      "};",
      "",
      "const buildUrl = (base: string, path: string, query?: RequestOptions['query']) => {",
      "  const origin = typeof window !== 'undefined' ? window.location.origin : 'http://localhost';",
      "  const baseAbs = base.startsWith('http') ? base : origin + base;",
      "  const url = new URL(path, baseAbs);",
      "  if (query) {",
      "    for (const [k, v] of Object.entries(query)) {",
      "      if (v === undefined || v === null) continue;",
      "      url.searchParams.set(k, String(v));",
      "    }",
      "  }",
      "  return url.toString();",
      "};",
      "",
      "export const createApiClient = (baseUrl: string, getAuthHeader?: () => string | undefined) => {",
      "  const request = async <T, B = unknown>(path: string, opts: RequestOptions<B> = {}): Promise<ApiResult<T>> => {",
      "    try {",
      "      const url = buildUrl(baseUrl, path, opts.query);",
      "      const auth = getAuthHeader?.();",
      "",
      "      const res = await fetch(url, {",
      "        method: opts.method ?? 'GET',",
      "        headers: {",
      "          ...(opts.body ? { 'Content-Type': 'application/json' } : {}),",
      "          ...(auth ? { Authorization: auth } : {}),",
      "          ...opts.headers,",
      "        },",
      "        body: opts.body && (opts.method ?? 'GET') !== 'GET' ? JSON.stringify(opts.body) : undefined,",
      "        body: (() => {",
"          const method = opts.method ?? 'GET';",
"          if (opts.body && method === 'GET') throw new Error('GET requests cannot include a body');",
"          return opts.body ? JSON.stringify(opts.body) : undefined;",
"        })(),",
      "        signal: opts.signal,",
      "      });",
      "",
      "      if (!res.ok) {",
      "        let details: unknown = undefined;",
      "        try { details = await res.json(); } catch { }",
      "        return { ok: false, error: { status: res.status, message: res.statusText, details } };",
      "      }",
      "",
      "      if (res.status === 204) return { ok: true, data: undefined as T };",
      "",
      "      const contentType = res.headers.get('content-type') ?? '';",
      "      if (!contentType.includes('application/json')) {",
      "        return { ok: true, data: (await res.text()) as unknown as T };",
      "      }",
      "",
      "      const data = (await res.json()) as T;",
      "      return { ok: true, data };",
      "    } catch (err) {",
      "      const message = err instanceof Error ? err.message : 'Request failed';",
      "      return { ok: false, error: { status: 0, message, details: err } };",
      "    }",
      "  };",
      "",
      "  return { request };",
      "};"
    ],
    "description": "API client"
  },
  "API / apiErrorNarrow": {
