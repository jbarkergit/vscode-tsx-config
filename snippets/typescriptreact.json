  "Generic Fetch": {
    "prefix": "fetch",
    "body": [
      "type ${1:DataType} = unknown;",
      "",
      "const callApi = async (",
      "  abortController: AbortController,",
      "  endpoint: string,",
      "  method: 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DEL'",
      "): Promise<${1:DataType}> => {",
      "  try {",
      "    const response = await fetch(endpoint, {",
      "      method,",
      "      headers: {",
      "        accept: 'application/json',",
      "        Authorization: `Bearer ${import.meta.env['VITE_READ_ACCESS_TOKEN']}`,",
      "      },",
      "      signal: abortController.signal,",
      "    });",
      "",
      "    if (!response.ok) throw new Error(response.statusText);",
      "",
      "    const data = (await response.json()) as ${1:DataType};",
      "    return data;",
      "  } catch (error) {",
      "    console.error(error);",
      "    throw error;",
      "  }",
      "};"
    ],
    "description": "Generic fetch helper without caching"
  },

  "Generic Fetch with Cache": {
    "prefix": "fetchCache",
    "body": [
      "type ${1:DataType} = unknown;",
      "",
      "const callApi = async (",
      "  abortController: AbortController,",
      "  endpoint: string,",
      "  method: 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DEL',",
      "  key?: string",
      "): Promise<${1:DataType}> => {",
      "  const cacheID = 'rest' as const;",
      "  const rawCache = sessionStorage.getItem(cacheID);",
      "  const cache = rawCache ? (JSON.parse(rawCache) as Record<string, ${1:DataType}>) : {};",
      "",
      "  try {",
      "    const cached = key ? cache[key] : undefined;",
      "    if (cached !== undefined) return cached;",
      "",
      "    const response = await fetch(endpoint, {",
      "      method,",
      "      headers: {",
      "        accept: 'application/json',",
      "        Authorization: `Bearer ${import.meta.env['VITE_READ_ACCESS_TOKEN']}`,",
      "      },",
      "      signal: abortController.signal,",
      "    });",
      "",
      "    if (!response.ok) throw new Error(response.statusText);",
      "",
      "    const data = (await response.json()) as ${1:DataType};",
      "",
      "    if (key) {",
      "      cache[key] = data;",
      "      sessionStorage.setItem(cacheID, JSON.stringify(cache));",
      "    }",
      "",
      "    return data;",
      "  } catch (error) {",
      "    console.error(`${key ? key + ':' : ''}`, error);",
      "    throw error;",
      "  }",
      "};"
    ],
    "description": "Generic fetch helper with optional sessionStorage caching"
  },

