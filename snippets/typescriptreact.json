      "  if (typeof window === 'undefined') return;",
      "",
      "  const loop = (time: number) => {",
      "    const prev = last.current ?? time;",
      "    const delta = time - prev;",
      "    last.current = time;",
      "",
      "    ${1}// use delta",
      "",
      "    frame.current = requestAnimationFrame(loop);",
      "  };",
      "",
      "  frame.current = requestAnimationFrame(loop);",
