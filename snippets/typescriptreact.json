  "Animation / useRafValue": {
    "prefix": "useRafValue",
    "body": [
      "export const useRafValue = <T,>(initial: T) => {",
      "  const [value, setValue] = useState(initial);",
      "  const next = useRef<T>(initial);",
      "  const frame = useRef<number | null>(null);",
      "",
      "  const setRaf = useCallback((v: T) => {",
      "    next.current = v;",
      "    if (frame.current !== null) return;",
      "    frame.current = requestAnimationFrame(() => {",
      "      frame.current = null;",
      "      setValue(next.current);",
      "    });",
      "  }, []);",
      "",
      "  useEffect(() => () => {",
      "    if (frame.current !== null) cancelAnimationFrame(frame.current);",
      "  }, []);",
      "",
      "  return [value, setRaf] as const;",
      "};"
    ],
    "description": "RAF batched state"
  },

  "Observers / useInView": {
    "prefix": "useIntersectionalObserver",
    "body": [
      "export const useInView = <T extends Element>(",
      "  options: IntersectionObserverInit = { rootMargin: '0px' }",
      ") => {",
      "  const ref = useRef<T>(null);",
      "  const [inView, setInView] = useState(false);",
      "",
      "  const { root, rootMargin, threshold } = options;",
      "",
      "  useEffect(() => {",
      "    const el = ref.current;",
      "    if (!el) return;",
      "",
      "    if (typeof IntersectionObserver === 'undefined') {",
      "      setInView(true);",
      "      return;",
      "    }",
      "",
      "    const observer = new IntersectionObserver(([entry]) => {",
      "      setInView(entry.isIntersecting);",
      "    }, { root, rootMargin, threshold });",
      "",
      "    observer.observe(el);",
      "    return () => observer.disconnect();",
      "  }, [root, rootMargin, threshold]);",
      "",
      "  return { ref, inView };",
      "};"
    ],
    "description": "IntersectionObserver hook"
  },

