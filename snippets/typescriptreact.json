      "  const onScroll = () => {",
      "    if (ticking) return;",
      "    ticking = true;",
      "    requestAnimationFrame(() => {",
      "      ${1}",
      "      ticking = false;",
      "    });",
      "  };",
      "",
      "  window.addEventListener('scroll', onScroll, { passive: true });",
      "  return () => window.removeEventListener('scroll', onScroll);",
      "}, []);"
    ],
    "description": "Scroll listener throttled with requestAnimationFrame"
  },
    "React Custom Hook / useRafValue": {
    "prefix": "useRafValue",
    "body": [
      "export const useRafValue = <T,>(initial: T) => {",
      "  const [value, setValue] = useState(initial);",
      "  const next = useRef(initial);",
      "  const frame = useRef<number | null>(null);",
      "",
      "  const setRaf = useCallback((v: T) => {",
      "    next.current = v;",
      "    if (typeof window === 'undefined') return;",
      "    if (frame.current !== null) return;",
      "    frame.current = requestAnimationFrame(() => {",
      "      frame.current = null;",
      "      setValue(next.current);",
      "    });",
      "  }, []);",
      "",
      "  useEffect(() => () => {",
      "    if (frame.current !== null) cancelAnimationFrame(frame.current);",
      "  }, []);",
      "",
      "  return [value, setRaf] as const;",
      "};"
    ],
    "description": "RAF-batched state setter"
  },
