  "React Custom Hook / useRafLoop": {
    "prefix": "useRafLoop",
    "body": [
      "export const useRafLoop = (",
      "  onFrame: (time: number, delta: number) => void,",
      "  opts?: { delta?: boolean; enabled?: boolean }",
      ") => {",
      "  const frame = useRef<number | null>(null);",
      "  const last = useRef<number | null>(null);",
      "",
      "  useEffect(() => {",
      "    if (typeof window === 'undefined') return;",
      "    if (opts?.enabled === false) return;",
      "",
      "    const loop = (time: number) => {",
      "      const prev = last.current ?? time;",
      "      const delta = opts?.delta === false ? 0 : time - prev;",
      "      last.current = time;",
      "",
      "      onFrame(time, delta);",
      "      frame.current = requestAnimationFrame(loop);",
      "    };",
      "",
      "    frame.current = requestAnimationFrame(loop);",
      "    return () => {",
      "      if (frame.current !== null) cancelAnimationFrame(frame.current);",
      "      frame.current = null;",
      "      last.current = null;",
      "    };",
      "  }, [onFrame, opts?.delta, opts?.enabled]);",
      "};"
    ],
    "description": "RAF loop (optionally computes delta) with cleanup"
  },
