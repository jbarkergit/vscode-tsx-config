   "React Form (uncontrolled)": {
    "prefix": "rfu",
    "body": [
      "import { useActionState } from 'react';",
      "",
      "type FormValues = {",
      "  name: string;",
      "};",
      "",
      "type FormErrors = Partial<Record<keyof FormValues, string>>;",
      "",
      "type ActionState = {",
      "  values: FormValues;",
      "  errors: FormErrors;",
      "  submitted?: boolean;",
      "};",
      "",
      "const initialState: ActionState = {",
      "  values: { name: '' },",
      "  errors: {},",
      "};",
      "",
      "function validate(values: FormValues): FormErrors {",
      "  const errors: FormErrors = {};",
      "  if (!values.name.trim()) errors.name = 'Required';",
      "  return errors;",
      "}",
      "",
      "async function submitToServer(values: FormValues) {",
      "  await new Promise((r) => setTimeout(r, 300));",
      "}",
      "",
      "const formActionCallback = async (_prev: ActionState, formData: FormData): Promise<ActionState> => {",
      "  const values: FormValues = {",
      "    name: String(formData.get('name') ?? ''),",
      "  };",
      "",
      "  const errors = validate(values);",
      "  if (Object.values(errors).some(Boolean)) {",
      "    return { values, errors, submitted: false };",
      "  }",
      "",
      "  try {",
      "    await submitToServer(values);",
      "    return { values, errors: {}, submitted: true };",
      "  } catch {",
      "    return {",
      "      values,",
      "      errors: { name: 'Submission failed. Try again.' },",
      "      submitted: false,",
      "    };",
      "  }",
      "};",
      "",
      "export function ${1:uncontrolledForm}() {",
      "  const [state, formAction, pending] = useActionState(formActionCallback, initialState);",
      "",
      "  return (",
      "    <form action={formAction} noValidate key={state.submitted ? 'submitted' : 'editing'}>",
      "      <label>",
      "        name",
      "        <input",
      "          name='name'",
      "          defaultValue={state.values.name}",
      "          aria-invalid={!!state.errors.name}",
      "          aria-describedby={state.errors.name ? 'name-error' : undefined}",
      "          disabled={pending}",
      "        />",
      "      </label>",
      "",
      "      {state.errors.name && (",
      "        <div id='name-error' role='alert'>",
      "          {state.errors.name}",
      "        </div>",
      "      )}",
      "",
      "      <button type='submit' disabled={pending}>",
      "        {pending ? 'Submitting...' : 'Submit'}",
      "      </button>",
      "",
      "      {state.submitted && <div role='status'>Saved</div>}",
      "    </form>",
      "  );",
      "}"
    ],
    "description": "React form using useActionState (uncontrolled)"
  },
  "React Form with useActionState + useDeferredValue": {
    "prefix": "rfc",
    "body": [
      "import { useActionState, useDeferredValue } from 'react';",
      "",
      "type FormValues = {",
      "  name: string;",
      "};",
      "",
      "type FormErrors = Partial<Record<keyof FormValues, string>>;",
      "",
      "type ActionState = {",
      "  values: FormValues;",
      "  errors: FormErrors;",
      "  submitted?: boolean;",
      "};",
      "",
      "const initialState: ActionState = {",
      "  values: { name: '' },",
      "  errors: {},",
      "};",
      "",
      "function validate(values: FormValues): FormErrors {",
      "  const errors: FormErrors = {};",
      "  if (!values.name.trim()) errors.name = 'Required';",
      "  return errors;",
      "}",
      "",
      "async function submitToServer(values: FormValues) {",
      "  await new Promise((r) => setTimeout(r, 300));",
      "}",
      "",
      "const formActionCallback = async (_prev: ActionState, formData: FormData): Promise<ActionState> => {",
      "  const values: FormValues = {",
      "    name: String(formData.get('name') ?? ''),",
      "  };",
      "",
      "  const errors = validate(values);",
      "  if (Object.values(errors).some(Boolean)) {",
      "    return { values, errors, submitted: false };",
      "  }",
      "",
      "  try {",
      "    await submitToServer(values);",
      "    return { values, errors: {}, submitted: true };",
      "  } catch {",
      "    return {",
      "      values,",
      "      errors: { name: 'Submission failed. Try again.' },",
      "      submitted: false,",
      "    };",
      "  }",
      "};",
      "",
      "export function ${1:controlledForm}() {",
      "  const [state, formAction, pending] = useActionState(formActionCallback, initialState);",
      "",
      "  const [name, setName] = React.useState(state.values.name);",
      "  const deferredName = useDeferredValue(name);",
      "",
      "  const liveErrors = React.useMemo(() => validate({ name: deferredName }), [deferredName]);",
      "  const nameError = state.errors.name ?? liveErrors.name;",
      "  const showSaved = state.submitted && name === state.values.name;",
      "",
      "  return (",
      "    <form action={formAction} noValidate>",
      "      <label>",
      "        name",
      "        <input",
      "          name='name'",
      "          value={name}",
      "          onChange={(e) => setName(e.target.value)}",
      "          aria-invalid={!!nameError}",
      "          aria-describedby={nameError ? 'name-error' : undefined}",
      "          disabled={pending}",
      "        />",
      "      </label>",
      "",
      "      {nameError && (",
      "        <div id='name-error' role='alert'>",
      "          {nameError}",
      "        </div>",
      "      )}",
      "",
      "      <button type='submit' disabled={pending || !!liveErrors.name}>",
      "        {pending ? 'Submitting...' : 'Submit'}",
      "      </button>",
      "",
      "      {showSaved && <div role='status'>Saved</div>}",
      "    </form>",
      "  );",
      "}"
    ],
    "description": "React form using useActionState with controlled input and useDeferredValue"
  },


