  "Context + Provider": {
    "prefix": "context",
    "body": [
      "import {",
      "  createContext,",
      "  type Dispatch,",
      "  type ReactNode,",
      "  type SetStateAction,",
      "  useContext,",
      "  useMemo,",
      "  useState,",
      "} from 'react';",
      "",
      "type ${TM_FILENAME_BASE}Type = {",
      "  ${1:state}: ${2:type};",
      "  set${1/(.*)/${1:/capitalize}/}: Dispatch<SetStateAction<${2:type}>>;",
      "};",
      "",
      "const ${TM_FILENAME_BASE}Context = createContext<${TM_FILENAME_BASE}Type | undefined>(undefined);",
      "",
      "export const ${TM_FILENAME_BASE}Provider = ({ children }: { children: ReactNode }) => {",
      "  const [${1:state}, set${1/(.*)/${1:/capitalize}/}] = useState<${2:type}>(${3:init});",
      "",
      "  const value = useMemo(() => ({ ${1:state}, set${1/(.*)/${1:/capitalize}/} }), [${1:state}]);",
      "  return <${TM_FILENAME_BASE}Context.Provider value={value}>{children}</${TM_FILENAME_BASE}Context.Provider>;",
      "};",
      "",
      "export const use${TM_FILENAME_BASE} = () => {",
      "  const context = useContext(${TM_FILENAME_BASE}Context);",
      "  if (!context) throw new Error('use${TM_FILENAME_BASE} cannot be consumed without a provider.');",
      "  return context;",
      "};"
    ],
    "description": "Context with provider and use hook"
  },

