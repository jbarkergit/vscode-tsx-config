  "useReducer Scaffold": {
  "prefix": "useReducer",
  "body": [
    "import { useReducer } from 'react';",
    "",
    "type Action =",
    "  | { type: 'ACTION_ONE'; payload?: any }",
    "  | { type: 'ACTION_TWO'; payload?: any };",
    "",
    "type State = {",
    "  ${1:count}: number;",
    "  ${2:flag}: boolean;",
    "};",
    "",
    "const initialState: State = {",
    "  ${1:count}: 0,",
    "  ${2:flag}: false,",
    "};",
    "",
    "const reducer = (state: State, action: Action): State => {",
    "  switch (action.type) {",
    "    case 'ACTION_ONE':",
    "      return { ...state, ${1:count}: state.${1:count} + 1 };",
    "    case 'ACTION_TWO':",
    "      return { ...state, ${2:flag}: !state.${2:flag} };",
    "    default:",
    "      throw new Error('Unhandled action type');",
    "  }",
    "};",
    "",
    "const [state, dispatch] = useReducer(reducer, initialState);",
    "",
    "// Example usage:",
    "// dispatch({ type: 'ACTION_ONE' });",
    "// dispatch({ type: 'ACTION_TWO', payload: {...} });"
  ],
  "description": "General useReducer scaffold with TypeScript types and actions"
},

