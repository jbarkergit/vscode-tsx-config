  "Generic API Wrapper Scaffold": {
    "prefix": "apiWrapper",
    "body": [
      "// Endpoint types placeholder",
      "const endpoints = {",
      "  never: {},",
      "  number: {},",
      "  string: {},",
      "} as const;",
      "",
      "// Key types",
      "type NeverKeys = keyof typeof endpoints.never;",
      "type NumberKeys = keyof typeof endpoints.number;",
      "type StringKeys = keyof typeof endpoints.string;",
      "",
      "// Argument shapes",
      "type ArgumentShapes<K> = K extends NeverKeys",
      "  ? K",
      "  : K extends NumberKeys",
      "    ? { [P in K]: number }",
      "    : K extends StringKeys",
      "      ? { [P in K]: string }",
      "      : undefined;",
      "",
      "// Union of all possible arguments",
      "type Argument = { [K in keyof unknown]: ArgumentShapes<K> }[keyof unknown];",
      "",
      "// Map argument to key",
      "type ArgumentToKey<T> = T extends keyof unknown",
      "  ? T",
      "  : T extends { [K in keyof unknown]?: unknown }",
      "    ? Extract<keyof T, keyof unknown>",
      "    : never;",
      "",
      "// Shape API response",
      "type CallResponse<T> = T extends unknown[]",
      "  ? { [K in keyof T]: T[K] extends Argument ? { key: ArgumentToKey<T[K]>; response: unknown } : never }",
      "  : { key: ArgumentToKey<T>; response: unknown };",
      "",
      "// Utility type guards",
      "function isArray<T>(value: T | T[]): value is T[] {",
      "  return Array.isArray(value);",
      "}",
      "",
      "function isObject<T>(value: T | object): value is object {",
      "  return value !== null && typeof value === 'object' && !Array.isArray(value);",
      "}",
      "",
      "export async function apiCall<T extends Argument | Argument[]>(args: T): Promise<CallResponse<T>> {",
      "  const parameters = isArray(args) ? args : [args];",
      "",
      "  const processed = parameters.map((param) => {",
      "    if (isObject(param)) {",
      "      return { key: Object.keys(param)[0], response: {} };",
      "    } else {",
      "      return { key: param, response: {} };",
      "    }",
      "  });",
      "",
      "  return isArray(args) ? (processed as CallResponse<T>) : (processed[0] as CallResponse<T>);",
      "}"
    ],
    "description": "Scaffold for a generic API wrapper with utility types, argument shapes, and array/object handling."
  },

